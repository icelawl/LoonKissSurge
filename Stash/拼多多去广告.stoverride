    - >-
      ^https:\/\/api\.pinduoduo\.com\/api\/caterham\/v3\/query\/personal\? - reject-dict
    - >-
      ^https:\/\/api\.pinduoduo\.com\/api\/brand-olay\/goods_detail\/bybt_guide\? - reject-dict
    - >-
      ^https:\/\/api\.pinduoduo\.com\/api\/engels\/reviews\/require\/append\? - reject-dict
    - >-
      ^https:\/\/api\.pinduoduo\.com\/api\/caterham\/v3\/query\/my_order_group\? - reject-dict
    - >-
      ^https:\/\/api\.pinduoduo\.com\/api\/caterham\/v3\/query\/likes\? - reject-dict
    - >-
      ^https:\/\/api\.pinduoduo\.com\/api\/phantom\/gbdbpdv\/extra\? - reject-dict
    - >-
      ^https:\/\/api\.pinduoduo\.com\/api\/manufacturer\/cross\/shortcut\/list\? - reject-dict
    - >-
      ^https:\/\/api\.pinduoduo\.com\/api\/dunkirk\/liveactivity\/push\/create\/url\/report\? - reject-dict
    - >-
      ^https:\/\/api\.pinduoduo\.com\/api\/growth\/nagato\/app\/index\/gather\? - reject-dict
    - >-
      ^https:\/\/api\.pinduoduo\.com\/api\/engels\/wait\/receive\/review\? - reject-dict
    - >-
      ^https:\/\/api\.pinduoduo\.com\/api\/buffon\/nasus\/recommend\? - reject-dict

  body-rewrite:
    - >-
      ^https:\/\/api\.pinduoduo\.com\/api\/alexa\/homepage\/hub\? response-jq delpaths([["result","dy_module","irregular_banner_dy"]])
    - >-
      ^https:\/\/api\.pinduoduo\.com\/api\/alexa\/homepage\/hub\? response-jq delpaths([["result","icon_set"]])
    - >-
      ^https:\/\/api\.pinduoduo\.com\/api\/alexa\/homepage\/hub\? response-jq delpaths([["result","search_bar_hot_query"]])
    - >-
      ^https:\/\/api\.pinduoduo\.com\/api\/alexa\/homepage\/hub\? response-jq delpaths([["result","dy_module","irregular_banner_dy"]])
    - >-
      ^https:\/\/api\.pinduoduo\.com\/api\/alexa\/homepage\/hub\? response-jq .result.bottom_tabs? |= map(select(.link | IN("index.html", "chat_list.html", "personal.html"))) | .result.buffer_bottom_tabs? |= map(select(.link | IN("index.html", "chat_list.html", "personal.html"))) | .result.all_top_opts |= map(del(.selected_image, .image, .height, .width))
    - >-
      ^https:\/\/api\.pinduoduo\.com\/search\? response-jq delpaths([["expansion"]])
    - >-
      ^https:\/\/api\.pinduoduo\.com\/api\/philo\/personal\/hub\? response-jq delpaths([["monthly_card_entrance"]])
    - >-
      ^https:\/\/api\.pinduoduo\.com\/api\/philo\/personal\/hub\? response-jq delpaths([["personal_center_style_v2_vo"]])
    - >-
      ^https:\/\/api\.pinduoduo\.com\/api\/philo\/personal\/hub\? response-jq delpaths([["icon_set","icons"]])
    - >-
      ^https:\/\/api\.pinduoduo\.com\/api\/philo\/personal\/hub\? response-jq delpaths([["icon_set","top_personal_icons"]])
    - >-
      ^https:\/\/api\.pinduoduo\.com\/api\/oak\/integration\/render\? response-jq delpaths([["bottom_section_list"]])
    - >-
      ^https:\/\/api\.pinduoduo\.com\/api\/oak\/integration\/render\? response-jq delpaths([["ui","bottom_section"]])
    - >-
      ^https:\/\/api\.pinduoduo\.com\/api\/oak\/integration\/render\? response-jq delpaths([["ui","live_section","float_info"]])
    - >-
      ^https:\/\/api\.pinduoduo\.com\/api\/caterham\/v3\/query\/order_detail_group\? response-jq delpaths([["data","goods_list"]])
    - >-
      ^https:\/\/api\.pinduoduo\.com\/order\/ response-jq delpaths([["marketing_banner_vo"]])
    - >-
      ^https:\/\/api\.pinduoduo\.com\/order\/ response-jq delpaths([["shipping","banner_above_recommend"]])
    - >-
      ^https:\/\/api\.pinduoduo\.com\/api\/aristotle\/order_list_v4\? response-jq .orders |= map(.order_buttons |= map(del(.order_growth_tip)))

