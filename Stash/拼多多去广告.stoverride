  去广告
loon_version: |-
  3.2.4(787)
homepage: |-
  https://hub.kelee.one
date: |-
  2026-02-28 20:52:18

rules:
  - AND,((URL-REGEX,"^http:\/\/((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\/d(\d)?"),(USER-AGENT,"*com.xunmeng.pinduoduo*")),REJECT
  - AND,((URL-REGEX,"^http:\/\/\[[0-9a-fA-F:]+\]\/d(\d)?\?"),(USER-AGENT,"*com.xunmeng.pinduoduo*")),REJECT
  - AND,((DOMAIN,api.pinduoduo.com),(PROTOCOL,QUIC)),REJECT
  - DOMAIN,titan.pinduoduo.com,REJECT
  - DOMAIN,xg.pinduoduo.com,REJECT
  - DOMAIN,cdl-1.pddpic.com,REJECT
  - DOMAIN,titan.pinduoduo.com,REJECT
  - DOMAIN,cdl-p2.pddpic.com,REJECT
  - DOMAIN,cd-1.pddpic.com,REJECT
  - DOMAIN,apm.pinduoduo.com,REJECT
  - DOMAIN,th-b.pinduoduo.com,REJECT
  - DOMAIN,ta.pinduoduo.com,REJECT
  - DOMAIN,th.pinduoduo.com,REJECT
  - DOMAIN,th-a.pinduoduo.com,REJECT
  - DOMAIN,ta-a.pinduoduo.com,REJECT
  - DOMAIN,meta.pinduoduo.com,REJECT
  - DOMAIN,apm-a.pinduoduo.com,REJECT

http:

  mitm:
    - "api.pinduoduo.com"

  url-rewrite:
    - >-
      ^https:\/\/api\.pinduoduo\.com\/api\/aristotle\/unrated_order_for_unreceived_tab\? - reject-dict
    - >-
      ^https:\/\/api\.pinduoduo\.com\/api\/aristotle\/query_order_list_tabs_element\? - reject-dict
    - >-
      ^https:\/\/api\.pinduoduo\.com\/api\/aquarius\/hungary\/global\/homepage\? - reject-dict
    - >-
      ^https:\/\/api\.pinduoduo\.com\/api\/caterham\/v3\/query\/order_express_group\? - reject-dict
    - >-
      ^https:\/\/api\.pinduoduo\.com\/search_hotquery\? - reject-dict
    - >-
      ^https:\/\/api\.pinduoduo\.com\/api\/zaire_biz\/chat\/resource\/get_list_data\? - reject-dict
    - >-
      ^https:\/\/api\.pinduoduo\.com\/api\/caterham\/v3\/query\/new_chat_group\? - reject-dict
