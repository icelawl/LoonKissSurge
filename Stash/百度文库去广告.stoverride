name: |-
  百度文库去广告
desc: |-
  移除开屏广告、横幅广告、弹窗广告、信息流推广、搜索发现、热门搜索、资料库搜索推荐，精简我的页面。
author: |-
  可莉🅥[https://github.com/luestr/ProxyResource/blob/main/README.md]
icon: |-
  https://raw.githubusercontent.com/luestr/IconResource/main/App_icon/120px/BaiduWenku.png
openUrl: |-
  https://apps.apple.com/app/id426340811
tag: |-
  去广告
loon_version: |-
  3.4.0(962)
homepage: |-
  https://hub.kelee.one
date: |-
  2026-06-01 17:11:35

http:

  mitm:
    - "appwk.baidu.com"
    - "tanbi.baidu.com"

  url-rewrite:
    - >-
      ^https:\/\/appwk\.baidu\.com\/xpage\/interface\/wknaad\? - reject-dict
    - >-
      ^https:\/\/appwk\.baidu\.com\/appapi\/search\/hot\? - reject-dict
    - >-
      ^https:\/\/appwk\.baidu\.com\/naapi\/search\/wkhotwords\? - reject-dict
    - >-
      ^https:\/\/appwk\.baidu\.com\/appapi\/task\/viptasklist\? - reject-dict
    - >-
      ^https:\/\/appwk\.baidu\.com\/activity\/interface\/wkapppopup\? - reject-dict
    - >-
      ^https:\/\/appwk\.baidu\.com\/appapi\/abg\/index\? - reject-dict
    - >-
      ^https:\/\/appwk\.baidu\.com\/naapi\/recommend\/recommenddoc\? - reject-dict
    - >-
      ^https:\/\/appwk\.baidu\.com\/naapi\/recommend\/vipdoccard\? - reject-dict

  script:
    - match: ^https:\/\/appwk\.baidu\.com\/appapi\/index\/home\?
      name: "body_rewrite_13_13"
      type: response
      require-body: true
      max-size: -1
      timeout: 30
      argument: |-
        %5B%5B%22json-del%22%2C%5B%22data.bannerInfo%22%2C%22data.bannerList%22%2C%22data.bannerListV2%22%5D%5D%5D

    - match: ^https:\/\/(appwk|tanbi)\.baidu\.com\/gsula\/sula\/syncmrecall$
      name: "body_rewrite_13_13"
      type: response
      require-body: true
      max-size: -1
      timeout: 30
      argument: |-
        %5B%5B%22json-del%22%2C%5B%22data.items%22%5D%5D%5D

    - match: ^https:\/\/appwk\.baidu\.com\/appapi\/index\/tab\?
      name: "body_rewrite_13_13"
      type: response
      require-body: true
      max-size: -1
      timeout: 30
      argument: |-
        %5B%5B%22json-del%22%2C%5B%22data%22%5D%5D%5D

    - match: ^https:\/\/appwk\.baidu\.com\/appapi\/forum\/feed\?reqMode=wenkuapp_main_feed
      name: "body_rewrite_13_13"
      type: response
      require-body: true
      max-size: -1
      timeout: 30
      argument: |-
        %5B%5B%22json-del%22%2C%5B%22data%22%5D%5D%5D

script-providers:
  "body_rewrite_13_13":
    url: https://raw.githubusercontent.com/Script-Hub-Org/Script-Hub/main/scripts/body-rewrite.js
    interval: 86400
