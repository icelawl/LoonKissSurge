  https://raw.githubusercontent.com/luestr/IconResource/main/App_icon/120px/QuarkScanking.png
openUrl: |-
  https://apps.apple.com/app/id6450447757
tag: |-
  去广告
loon_version: |-
  3.4.0(962)
homepage: |-
  https://hub.kelee.one
date: |-
  2026-06-01 17:11:35

