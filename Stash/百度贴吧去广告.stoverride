      name: "echoResponse_22"
      type: request
      timeout: 60
      argument: |-
        text=%7B%22no%22%3A0%2C%22error%22%3A%22success%22%7D&status-code=200

    - match: ^https?:\/\/tieba(?:c)?\.baidu\.com\/c\/(f\/excellent\/personalized|f\/frs\/page|b\/ad\/adBid|f\/ad\/getFeedAd|f\/pb\/page|f\/frs\/generalTabList)\?cmd=\d+&format=protobuf
      name: "ProtoBuf处理_34"
      type: response
      require-body: true
      binary-mode: true
      timeout: 10
      argument: |-
        [ "true"]

script-providers:
