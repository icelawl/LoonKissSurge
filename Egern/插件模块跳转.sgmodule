name: 插件模块跳转
description:
 色鸡 可莉插件中心跳转到 Egern  如不生效 清理浏览器缓存即可
icon: https://iili.io/BDPVJ1I.png
homepage: https://hub.kelee.one
body_rewrites:
  - response_regex:
      match: https://(pluginhub|hub)\.kelee\.one/
      find: loon://import\?plugin=
      replace: egern:///modules/new?url=
  - response_regex:
      match: https://surge\.qingr\.moe/
      find: surge:///install-module\?url=
      replace: egern:///modules/new?url=
mitm:
  hostnames:
    includes:
      - pluginhub.kelee.one
      - hub.kelee.one
      - surge.qingr.moe